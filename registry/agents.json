{
  "version": 1,
  "agents": [
    {
      "id": "hermes",
      "name": "Hermes",
      "tagline": "Personal AI assistant on Telegram and Discord",
      "homepage": "https://hermes-agent.nousresearch.com/",
      "install": {
        "npm": null,
        "brew": null,
        "script": {
          "unix": "https://hermes-agent.nousresearch.com/install.sh",
          "windows": "https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.ps1"
        },
        "binary": "hermes",
        "non_interactive_args": ["--skip-setup"],
        "macos_launch_agent_disable": {
          "label": "ai.hermes.gateway",
          "plist_path": "~/Library/LaunchAgents/ai.hermes.gateway.plist"
        }
      },
      "config_paths": ["~/.hermes/config.yaml", "~/.config/hermes/config.yaml"],
      "config_snippet": "registry/snippets/hermes.yaml",
      "identity_path": "~/.hermes/SOUL.md",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["telegram-bot-token", "discord-bot-token"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "optional_services": ["telegram", "discord"],
      "mcp_compatible": true,
      "chat_capable": true,
      "supported_versions": ">=2.0.0",
      "min_foreman_version": "0.1.2",
      "provider_mapping": {
        "openai": {
          "preferred": "via-openrouter",
          "variants": {
            "via-openrouter": {
              "label": "OpenAI models via OpenRouter (recommended)",
              "writes": {
                "model.default": "openai/${model}",
                "model.provider": "openrouter",
                "model.base_url": ""
              },
              "env_vars": {
                "OPENROUTER_API_KEY": "${secret:openrouter-key}"
              },
              "required_secret": "openrouter-key",
              "secret_acquisition": {
                "name": "OpenRouter API key",
                "url": "https://openrouter.ai/keys",
                "note": "Hermes routes OpenAI calls through OpenRouter — there's no native OpenAI provider in Hermes' enum. Get a key (free trial available), paste it here, and Hermes will use it to call OpenAI models."
              }
            },
            "via-codex-oauth": {
              "label": "OpenAI Codex OAuth (uses your ChatGPT subscription)",
              "writes": {
                "model.default": "${model}",
                "model.provider": "openai-codex",
                "model.base_url": ""
              },
              "interactive_setup": "hermes auth add openai-codex --type oauth",
              "post_setup_verify": "hermes auth status openai-codex",
              "required_secret": null,
              "secret_acquisition": {
                "name": "Hermes' OpenAI Codex OAuth session",
                "note": "Hermes manages its OWN Codex OAuth credentials (separate from the Codex CLI's auth.json). Run `hermes auth add openai-codex --type oauth` and complete the browser flow — Foreman auto-runs this on Done."
              }
            }
          }
        },
        "anthropic": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "Anthropic direct API",
              "writes": {
                "model.default": "anthropic/${model}",
                "model.provider": "anthropic",
                "model.base_url": ""
              },
              "env_vars": {
                "ANTHROPIC_API_KEY": "${secret:anthropic-key}"
              },
              "required_secret": "anthropic-key",
              "secret_acquisition": {
                "name": "Anthropic API key",
                "url": "https://console.anthropic.com/",
                "note": "Hermes has a native Anthropic provider — paste your Anthropic API key for direct access."
              }
            }
          }
        },
        "gemini": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "Google AI Studio (Gemini direct)",
              "writes": {
                "model.default": "google/${model}",
                "model.provider": "google",
                "model.base_url": ""
              },
              "env_vars": {
                "GOOGLE_API_KEY": "${secret:gemini-key}",
                "GEMINI_API_KEY": "${secret:gemini-key}"
              },
              "required_secret": "gemini-key",
              "secret_acquisition": {
                "name": "Google AI Studio API key",
                "url": "https://aistudio.google.com/app/apikey",
                "note": "Hermes uses Google's native Gemini API via the openai-compatible endpoint."
              }
            }
          }
        }
      },
      "daemon": {
        "command": "hermes",
        "args": ["gateway"],
        "label": "Telegram/Discord gateway"
      },
      "mcp_register_cli": {
        "command_template": "hermes mcp add foreman --command {wrapper_path}",
        "verify_template": "hermes mcp list",
        "note": "Hermes' --args parsing strips multi-token strings, so we point it at a one-line wrapper instead. Foreman writes the wrapper for you; just run the hermes command above once.",
        "wrapper": {
          "path_template": "~/.foreman/wrappers/{agent_id}-mcp.sh",
          "content_template": "#!/usr/bin/env bash\nexec foreman mcp-stdio --source {agent_id}\n"
        }
      },
      "secret_projection": {
        "env_file": "~/.hermes/.env",
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" },
          "OPENAI_API_KEY": { "from_secret": "openai-key", "if_provider": "openai" },
          "OPENROUTER_API_KEY": { "from_secret": "openrouter-key", "if_provider": "openrouter" },
          "GEMINI_API_KEY": { "from_secret": "gemini-key", "if_provider": "gemini" },
          "TELEGRAM_BOT_TOKEN": { "from_secret": "telegram-bot-token", "if_service": "telegram" },
          "TELEGRAM_ALLOWED_USERS": { "from_secret": "telegram-chat-id", "if_service": "telegram" },
          "DISCORD_BOT_TOKEN": { "from_secret": "discord-bot-token", "if_service": "discord" },
          "SLACK_BOT_TOKEN": { "from_secret": "slack-bot-token", "if_service": "slack" }
        },
        "launch": [
          { "command": "hermes", "label": "chat" },
          { "command": "hermes gateway", "label": "daemon (Telegram/Discord)" }
        ],
        "provider_check": {
          "path": "~/.hermes/config.yaml",
          "format": "yaml",
          "key": "provider",
          "fix_command": "hermes model"
        },
        "config_overrides": {
          "path": "~/.hermes/config.yaml",
          "format": "yaml",
          "writes": [
            {
              "if_provider": "openai",
              "set": {
                "model.default": "openai/gpt-4o-mini",
                "model.provider": "openai",
                "model.base_url": "https://api.openai.com/v1"
              }
            },
            {
              "if_provider": "anthropic",
              "set": {
                "model.default": "anthropic/claude-haiku-4-5-20251001",
                "model.provider": "anthropic",
                "model.base_url": "https://api.anthropic.com/v1"
              }
            },
            {
              "if_provider": "gemini",
              "set": {
                "model.default": "google/gemini-2.0-flash",
                "model.provider": "google",
                "model.base_url": "https://generativelanguage.googleapis.com/v1beta/openai"
              }
            }
          ]
        }
      }
    },
    {
      "id": "openclaw",
      "name": "OpenClaw",
      "tagline": "Multi-channel assistant with a lobster-themed TUI",
      "homepage": "https://openclaw.ai/",
      "install": {
        "npm": "openclaw",
        "brew": null,
        "script": "https://openclaw.ai/install.sh",
        "binary": "openclaw",
        "config_template_path": "registry/templates/openclaw.json",
        "post_config_commands": [
          "openclaw gateway install"
        ]
      },
      "config_paths": [
        "~/.openclaw/openclaw.json",
        "~/.config/openclaw/openclaw.json"
      ],
      "config_snippet": "registry/snippets/openclaw.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["openai-key", "slack-bot-token"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "optional_services": ["telegram", "discord", "slack"],
      "mcp_compatible": true,
      "mcp_format": "nested",
      "chat_capable": true,
      "supported_versions": ">=1.4.0",
      "min_foreman_version": "0.1.2",
      "provider_mapping": {
        "openai": {
          "preferred": "native",
          "variants": {
            "native": {
              "label": "OpenAI direct API",
              "writes": {
                "agents.defaults.model.primary": "openai/${model}"
              },
              "env_vars": {
                "OPENAI_API_KEY": "${secret:openai-key}"
              },
              "required_secret": "openai-key",
              "secret_acquisition": {
                "name": "OpenAI API key",
                "url": "https://platform.openai.com/api-keys"
              }
            }
          }
        },
        "anthropic": {
          "preferred": "native",
          "variants": {
            "native": {
              "label": "Anthropic direct API",
              "writes": {
                "agents.defaults.model.primary": "anthropic/${model}"
              },
              "env_vars": {
                "ANTHROPIC_API_KEY": "${secret:anthropic-key}"
              },
              "required_secret": "anthropic-key",
              "secret_acquisition": {
                "name": "Anthropic API key",
                "url": "https://console.anthropic.com/"
              }
            }
          }
        },
        "gemini": {
          "preferred": "native",
          "variants": {
            "native": {
              "label": "Google Gemini direct API",
              "writes": {
                "agents.defaults.model.primary": "google/${model}"
              },
              "env_vars": {
                "GEMINI_API_KEY": "${secret:gemini-key}"
              },
              "required_secret": "gemini-key",
              "secret_acquisition": {
                "name": "Google AI Studio API key",
                "url": "https://aistudio.google.com/app/apikey"
              }
            }
          }
        }
      },
      "daemon": {
        "command": "openclaw",
        "args": ["gateway"],
        "label": "OpenClaw daemon"
      },
      "secret_projection": {
        "json_env": {
          "path": "~/.openclaw/openclaw.json",
          "section": "env"
        },
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" },
          "OPENAI_API_KEY": { "from_secret": "openai-key", "if_provider": "openai" },
          "GEMINI_API_KEY": { "from_secret": "gemini-key", "if_provider": "gemini" }
        },
        "json_channels": {
          "path": "~/.openclaw/openclaw.json",
          "channels": {
            "telegram": {
              "path": "channels.telegram.botToken",
              "from_secret": "telegram-bot-token",
              "if_service": "telegram"
            },
            "discord": {
              "path": "channels.discord.token",
              "from_secret": "discord-bot-token",
              "if_service": "discord"
            },
            "slack": {
              "path": "channels.slack.botToken",
              "from_secret": "slack-bot-token",
              "if_service": "slack"
            }
          }
        },
        "launch": [
          { "command": "openclaw", "label": "chat" },
          { "command": "openclaw gateway", "label": "daemon" }
        ],
        "provider_check": {
          "path": "~/.openclaw/openclaw.json",
          "format": "json",
          "key": "provider",
          "fix_command": "openclaw config set provider <name>"
        },
        "config_overrides": {
          "path": "~/.openclaw/openclaw.json",
          "format": "json",
          "writes": [
            {
              "if_provider": "openai",
              "set": {
                "agents.defaults.model.primary": "openai/gpt-4o-mini"
              }
            },
            {
              "if_provider": "anthropic",
              "set": {
                "agents.defaults.model.primary": "anthropic/claude-haiku-4-5-20251001"
              }
            },
            {
              "if_provider": "gemini",
              "set": {
                "agents.defaults.model.primary": "google/gemini-2.0-flash"
              }
            },
            {
              "if_service": "telegram",
              "set": {
                "channels.telegram.dmPolicy": "allowlist"
              }
            }
          ]
        },
        "security_bootstrap": {
          "path": "~/.openclaw/openclaw.json",
          "format": "json",
          "auth_token": {
            "key": "gateway.auth.token",
            "bytes": 32,
            "encoding": "hex"
          },
          "owner_allowlist": {
            "key": [
              "commands.ownerAllowFrom",
              "channels.telegram.allowFrom"
            ],
            "from_secret": "telegram-chat-id",
            "item_template": "telegram:{value}",
            "if_service": "telegram"
          }
        }
      }
    },
    {
      "id": "codex",
      "name": "Codex",
      "tagline": "OpenAI's terminal coding agent",
      "homepage": "https://developers.openai.com/codex",
      "install": {
        "npm": "@openai/codex",
        "brew": null,
        "script": null,
        "binary": "codex"
      },
      "config_paths": ["~/.codex/config.toml"],
      "config_snippet": null,
      "identity_path": "~/.codex/AGENTS.md",
      "mcp_servers_key": "mcp_servers",
      "required_secrets": [],
      "optional_secrets": ["openai-key"],
      "llm_compat": ["openai"],
      "optional_services": ["github"],
      "mcp_compatible": true,
      "task_command_template": "codex exec \"{task}\"",
      "task_timeout_seconds": 600,
      "task_env_strip": ["OPENAI_API_KEY"],
      "task_model_flag": "-m",
      "task_skip_permissions_flag": "--sandbox workspace-write",
      "supported_versions": ">=0.100.0",
      "min_foreman_version": "0.1.2",
      "provider_mapping": {
        "openai": {
          "preferred": "oauth",
          "variants": {
            "oauth": {
              "label": "ChatGPT account OAuth (recommended — covered by your subscription)",
              "toml_writes": [
                {
                  "path": "~/.codex/config.toml",
                  "key": "preferred_auth_method",
                  "value": "chatgpt"
                }
              ],
              "interactive_setup": "codex login",
              "post_setup_verify": "codex login status",
              "required_secret": null,
              "secret_acquisition": {
                "name": "ChatGPT account login",
                "note": "Codex OAuth uses your existing ChatGPT subscription — no API key needed. After Foreman setup completes, run `codex login` once in a separate terminal."
              }
            },
            "api-key": {
              "label": "OpenAI API key (pay-per-token)",
              "toml_writes": [
                {
                  "path": "~/.codex/config.toml",
                  "key": "preferred_auth_method",
                  "value": "apikey"
                }
              ],
              "auth_json_writes": {
                "path": "~/.codex/auth.json",
                "key": "OPENAI_API_KEY",
                "value": "${secret:openai-key}"
              },
              "required_secret": "openai-key",
              "secret_acquisition": {
                "name": "OpenAI API key",
                "url": "https://platform.openai.com/api-keys"
              }
            }
          }
        }
      },
      "secret_projection": {
        "toml_writes": [
          { "path": "~/.codex/config.toml", "key": "preferred_auth_method", "value": "apikey" }
        ],
        "auth_json": {
          "path": "~/.codex/auth.json",
          "key": "OPENAI_API_KEY",
          "from_secret": "openai-key",
          "if_provider": "openai"
        },
        "launch": "codex"
      }
    },
    {
      "id": "claude-code",
      "name": "Claude Code",
      "tagline": "Anthropic's official terminal coding agent",
      "homepage": "https://github.com/anthropics/claude-code",
      "install": {
        "npm": "@anthropic-ai/claude-code",
        "brew": null,
        "binary": "claude"
      },
      "config_paths": [
        "~/.claude/settings.json",
        "~/.config/claude-code/settings.json"
      ],
      "config_snippet": "registry/snippets/claude-code.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": [],
      "llm_compat": ["anthropic"],
      "optional_services": ["github"],
      "mcp_compatible": true,
      "task_command_template": "claude --print \"{task}\"",
      "task_timeout_seconds": 600,
      "task_env_strip": ["ANTHROPIC_API_KEY"],
      "task_model_flag": "--model",
      "task_skip_permissions_flag": "--dangerously-skip-permissions",
      "supported_versions": ">=0.5.0",
      "min_foreman_version": "0.1.2",
      "provider_mapping": {
        "anthropic": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "Anthropic direct API",
              "env_vars": {
                "ANTHROPIC_API_KEY": "${secret:anthropic-key}"
              },
              "required_secret": "anthropic-key",
              "secret_acquisition": {
                "name": "Anthropic API key",
                "url": "https://console.anthropic.com/"
              }
            },
            "oauth": {
              "label": "Claude Pro/Max subscription (OAuth)",
              "interactive_setup": "claude auth login",
              "post_setup_verify": "claude auth status",
              "required_secret": null,
              "secret_acquisition": {
                "name": "Claude Pro/Max account",
                "note": "Claude Code uses your existing Claude Pro/Max subscription — no API key needed. After Foreman setup completes, run `claude auth login` once in a separate terminal."
              }
            }
          }
        }
      },
      "secret_projection": {
        "json_env": {
          "path": "~/.claude/settings.json",
          "section": "env"
        },
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" }
        },
        "launch": "claude"
      }
    },
    {
      "id": "zeroclaw",
      "name": "ZeroClaw",
      "tagline": "Minimalist Rust-based AI agent runtime for low-resource boxes",
      "homepage": "https://github.com/zeroclaw-labs/zeroclaw",
      "install": {
        "npm": null,
        "brew": null,
        "script": "https://raw.githubusercontent.com/zeroclaw-labs/zeroclaw/master/install.sh",
        "binary": "zeroclaw"
      },
      "config_paths": ["~/.zeroclaw/config.toml"],
      "config_snippet": "registry/snippets/zeroclaw.yaml",
      "required_secrets": [],
      "optional_secrets": ["anthropic-key", "openai-key"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "mcp_compatible": true,
      "chat_capable": true,
      "supported_versions": ">=0.3.0",
      "min_foreman_version": "0.1.2",
      "provider_mapping": {
        "openai": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "OpenAI direct API",
              "toml_writes": [
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "default_provider",
                  "value": "openai"
                },
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "api_key",
                  "value": "${secret:openai-key}"
                }
              ],
              "required_secret": "openai-key",
              "secret_acquisition": {
                "name": "OpenAI API key",
                "url": "https://platform.openai.com/api-keys"
              }
            }
          }
        },
        "anthropic": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "Anthropic direct API",
              "toml_writes": [
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "default_provider",
                  "value": "anthropic"
                },
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "api_key",
                  "value": "${secret:anthropic-key}"
                }
              ],
              "required_secret": "anthropic-key",
              "secret_acquisition": {
                "name": "Anthropic API key",
                "url": "https://console.anthropic.com/"
              }
            }
          }
        },
        "gemini": {
          "preferred": "direct",
          "variants": {
            "direct": {
              "label": "Google Gemini direct API",
              "toml_writes": [
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "default_provider",
                  "value": "gemini"
                },
                {
                  "path": "~/.zeroclaw/config.toml",
                  "key": "api_key",
                  "value": "${secret:gemini-key}"
                }
              ],
              "required_secret": "gemini-key",
              "secret_acquisition": {
                "name": "Google AI Studio API key",
                "url": "https://aistudio.google.com/app/apikey"
              }
            }
          }
        }
      },
      "secret_projection": {
        "toml_writes": [
          { "path": "~/.zeroclaw/config.toml", "key": "default_provider", "value": "anthropic" },
          {
            "path": "~/.zeroclaw/config.toml",
            "key": "api_key",
            "value": { "from_secret": "anthropic-key" }
          }
        ],
        "launch": "zeroclaw"
      }
    },
    {
      "id": "generic-mcp",
      "name": "Generic MCP server",
      "tagline": "Custom MCP-compatible agent — bring your own binary",
      "homepage": "https://modelcontextprotocol.io/",
      "install": { "npm": null, "brew": null },
      "config_paths": [],
      "config_snippet": null,
      "required_secrets": [],
      "optional_secrets": [],
      "llm_compat": [],
      "mcp_compatible": true,
      "supported_versions": "*",
      "min_foreman_version": "0.1.2"
    }
  ]
}
