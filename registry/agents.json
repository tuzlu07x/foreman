{
  "version": 1,
  "agents": [
    {
      "id": "hermes",
      "name": "Hermes",
      "tagline": "Personal AI assistant on Telegram and Discord",
      "homepage": "https://hermes-agent.nousresearch.com/",
      "install": {
        "npm": null,
        "brew": null,
        "script": "https://hermes-agent.nousresearch.com/install.sh",
        "binary": "hermes"
      },
      "config_paths": ["~/.hermes/config.yaml", "~/.config/hermes/config.yaml"],
      "config_snippet": "registry/snippets/hermes.yaml",
      "identity_path": "~/.hermes/SOUL.md",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["telegram-bot-token", "discord-bot-token"],
      "llm_compat": ["anthropic", "openai"],
      "mcp_compatible": true,
      "supported_versions": ">=2.0.0",
      "min_foreman_version": "0.1.2"
    },
    {
      "id": "openclaw",
      "name": "OpenClaw",
      "tagline": "Multi-channel assistant with a lobster-themed TUI",
      "homepage": "https://openclaw.ai/",
      "install": {
        "npm": "openclaw",
        "brew": null,
        "script": "https://openclaw.ai/install.sh",
        "binary": "openclaw"
      },
      "config_paths": [
        "~/.openclaw/config.json",
        "~/.config/openclaw/config.json"
      ],
      "config_snippet": "registry/snippets/openclaw.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["openai-key", "slack-bot-token"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "mcp_compatible": true,
      "supported_versions": ">=1.4.0",
      "min_foreman_version": "0.1.2"
    },
    {
      "id": "codex",
      "name": "Codex",
      "tagline": "OpenAI's terminal coding agent",
      "homepage": "https://developers.openai.com/codex",
      "install": {
        "npm": "@openai/codex",
        "brew": null,
        "script": null,
        "binary": "codex"
      },
      "config_paths": ["~/.codex/config.toml"],
      "config_snippet": null,
      "mcp_servers_key": "mcp_servers",
      "required_secrets": [],
      "optional_secrets": ["openai-key"],
      "llm_compat": ["openai"],
      "mcp_compatible": true,
      "supported_versions": ">=0.100.0",
      "min_foreman_version": "0.1.2"
    },
    {
      "id": "claude-code",
      "name": "Claude Code",
      "tagline": "Anthropic's official terminal coding agent",
      "homepage": "https://github.com/anthropics/claude-code",
      "install": {
        "npm": "@anthropic-ai/claude-code",
        "brew": null,
        "binary": "claude"
      },
      "config_paths": [
        "~/.claude/settings.json",
        "~/.config/claude-code/settings.json"
      ],
      "config_snippet": "registry/snippets/claude-code.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": [],
      "llm_compat": ["anthropic"],
      "mcp_compatible": true,
      "supported_versions": ">=0.5.0",
      "min_foreman_version": "0.1.2"
    },
    {
      "id": "zeroclaw",
      "name": "ZeroClaw",
      "tagline": "Minimalist Rust-based AI agent runtime for low-resource boxes",
      "homepage": "https://github.com/zeroclaw-labs/zeroclaw",
      "install": {
        "npm": null,
        "brew": null,
        "script": "https://raw.githubusercontent.com/zeroclaw-labs/zeroclaw/master/install.sh",
        "binary": "zeroclaw"
      },
      "config_paths": ["~/.zeroclaw/config.toml"],
      "config_snippet": "registry/snippets/zeroclaw.yaml",
      "required_secrets": [],
      "optional_secrets": ["anthropic-key", "openai-key"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "mcp_compatible": true,
      "supported_versions": ">=0.3.0",
      "min_foreman_version": "0.1.2"
    },
    {
      "id": "generic-mcp",
      "name": "Generic MCP server",
      "tagline": "Custom MCP-compatible agent — bring your own binary",
      "homepage": "https://modelcontextprotocol.io/",
      "install": { "npm": null, "brew": null },
      "config_paths": [],
      "config_snippet": null,
      "required_secrets": [],
      "optional_secrets": [],
      "llm_compat": [],
      "mcp_compatible": true,
      "supported_versions": "*",
      "min_foreman_version": "0.1.2"
    }
  ]
}
