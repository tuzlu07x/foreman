{
  "version": 1,
  "agents": [
    {
      "id": "hermes",
      "name": "Hermes",
      "tagline": "Personal AI assistant on Telegram and Discord",
      "homepage": "https://hermes-agent.nousresearch.com/",
      "install": {
        "npm": null,
        "brew": null,
        "script": "https://hermes-agent.nousresearch.com/install.sh",
        "binary": "hermes"
      },
      "config_paths": ["~/.hermes/config.yaml", "~/.config/hermes/config.yaml"],
      "config_snippet": "registry/snippets/hermes.yaml",
      "identity_path": "~/.hermes/SOUL.md",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["telegram-bot-token", "discord-bot-token"],
      "llm_compat": ["anthropic", "openai"],
      "optional_services": ["telegram", "discord"],
      "mcp_compatible": true,
      "supported_versions": ">=2.0.0",
      "min_foreman_version": "0.1.2",
      "daemon": {
        "command": "hermes",
        "args": ["gateway"],
        "label": "Telegram/Discord gateway"
      },
      "mcp_register_cli": {
        "command_template": "hermes mcp add foreman --command {wrapper_path}",
        "verify_template": "hermes mcp list",
        "note": "Hermes' --args parsing strips multi-token strings, so we point it at a one-line wrapper instead. Foreman writes the wrapper for you; just run the hermes command above once.",
        "wrapper": {
          "path_template": "~/.foreman/wrappers/{agent_id}-mcp.sh",
          "content_template": "#!/usr/bin/env bash\nexec foreman mcp-stdio --source {agent_id}\n"
        }
      },
      "secret_projection": {
        "env_file": "~/.hermes/.env",
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" },
          "OPENAI_API_KEY": { "from_secret": "openai-key", "if_provider": "openai" },
          "OPENROUTER_API_KEY": { "from_secret": "openrouter-key", "if_provider": "openrouter" },
          "GEMINI_API_KEY": { "from_secret": "gemini-key", "if_provider": "gemini" },
          "TELEGRAM_BOT_TOKEN": { "from_secret": "telegram-bot-token", "if_service": "telegram" },
          "TELEGRAM_ALLOWED_USERS": { "from_secret": "telegram-chat-id", "if_service": "telegram" },
          "DISCORD_BOT_TOKEN": { "from_secret": "discord-bot-token", "if_service": "discord" },
          "SLACK_BOT_TOKEN": { "from_secret": "slack-bot-token", "if_service": "slack" }
        },
        "launch": [
          { "command": "hermes", "label": "chat" },
          { "command": "hermes gateway", "label": "daemon (Telegram/Discord)" }
        ],
        "provider_check": {
          "path": "~/.hermes/config.yaml",
          "format": "yaml",
          "key": "provider",
          "fix_command": "hermes model"
        }
      }
    },
    {
      "id": "openclaw",
      "name": "OpenClaw",
      "tagline": "Multi-channel assistant with a lobster-themed TUI",
      "homepage": "https://openclaw.ai/",
      "install": {
        "npm": "openclaw",
        "brew": null,
        "script": "https://openclaw.ai/install.sh",
        "binary": "openclaw"
      },
      "config_paths": [
        "~/.openclaw/openclaw.json",
        "~/.config/openclaw/openclaw.json"
      ],
      "config_snippet": "registry/snippets/openclaw.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": ["openai-key", "slack-bot-token"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "optional_services": ["telegram", "discord", "slack"],
      "mcp_compatible": true,
      "supported_versions": ">=1.4.0",
      "min_foreman_version": "0.1.2",
      "daemon": {
        "command": "openclaw",
        "args": ["gateway"],
        "label": "OpenClaw daemon"
      },
      "secret_projection": {
        "json_env": {
          "path": "~/.openclaw/openclaw.json",
          "section": "env"
        },
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" },
          "OPENAI_API_KEY": { "from_secret": "openai-key", "if_provider": "openai" },
          "GEMINI_API_KEY": { "from_secret": "gemini-key", "if_provider": "gemini" }
        },
        "json_channels": {
          "path": "~/.openclaw/openclaw.json",
          "channels": {
            "telegram": {
              "path": "channels.telegram.botToken",
              "from_secret": "telegram-bot-token",
              "if_service": "telegram"
            },
            "discord": {
              "path": "channels.discord.token",
              "from_secret": "discord-bot-token",
              "if_service": "discord"
            },
            "slack": {
              "path": "channels.slack.botToken",
              "from_secret": "slack-bot-token",
              "if_service": "slack"
            }
          }
        },
        "launch": [
          { "command": "openclaw", "label": "chat" },
          { "command": "openclaw gateway", "label": "daemon" }
        ],
        "provider_check": {
          "path": "~/.openclaw/openclaw.json",
          "format": "json",
          "key": "provider",
          "fix_command": "openclaw config set provider <name>"
        }
      }
    },
    {
      "id": "codex",
      "name": "Codex",
      "tagline": "OpenAI's terminal coding agent",
      "homepage": "https://developers.openai.com/codex",
      "install": {
        "npm": "@openai/codex",
        "brew": null,
        "script": null,
        "binary": "codex"
      },
      "config_paths": ["~/.codex/config.toml"],
      "config_snippet": null,
      "mcp_servers_key": "mcp_servers",
      "required_secrets": [],
      "optional_secrets": ["openai-key"],
      "llm_compat": ["openai"],
      "optional_services": ["github"],
      "mcp_compatible": true,
      "supported_versions": ">=0.100.0",
      "min_foreman_version": "0.1.2",
      "secret_projection": {
        "toml_writes": [
          { "path": "~/.codex/config.toml", "key": "preferred_auth_method", "value": "apikey" }
        ],
        "auth_json": {
          "path": "~/.codex/auth.json",
          "key": "OPENAI_API_KEY",
          "from_secret": "openai-key",
          "if_provider": "openai"
        },
        "launch": "codex"
      }
    },
    {
      "id": "claude-code",
      "name": "Claude Code",
      "tagline": "Anthropic's official terminal coding agent",
      "homepage": "https://github.com/anthropics/claude-code",
      "install": {
        "npm": "@anthropic-ai/claude-code",
        "brew": null,
        "binary": "claude"
      },
      "config_paths": [
        "~/.claude/settings.json",
        "~/.config/claude-code/settings.json"
      ],
      "config_snippet": "registry/snippets/claude-code.yaml",
      "required_secrets": ["anthropic-key"],
      "optional_secrets": [],
      "llm_compat": ["anthropic"],
      "optional_services": ["github"],
      "mcp_compatible": true,
      "supported_versions": ">=0.5.0",
      "min_foreman_version": "0.1.2",
      "secret_projection": {
        "json_env": {
          "path": "~/.claude/settings.json",
          "section": "env"
        },
        "env_vars": {
          "ANTHROPIC_API_KEY": { "from_secret": "anthropic-key", "if_provider": "anthropic" }
        },
        "launch": "claude"
      }
    },
    {
      "id": "zeroclaw",
      "name": "ZeroClaw",
      "tagline": "Minimalist Rust-based AI agent runtime for low-resource boxes",
      "homepage": "https://github.com/zeroclaw-labs/zeroclaw",
      "install": {
        "npm": null,
        "brew": null,
        "script": "https://raw.githubusercontent.com/zeroclaw-labs/zeroclaw/master/install.sh",
        "binary": "zeroclaw"
      },
      "config_paths": ["~/.zeroclaw/config.toml"],
      "config_snippet": "registry/snippets/zeroclaw.yaml",
      "required_secrets": [],
      "optional_secrets": ["anthropic-key", "openai-key"],
      "llm_compat": ["anthropic", "openai", "gemini"],
      "mcp_compatible": true,
      "supported_versions": ">=0.3.0",
      "min_foreman_version": "0.1.2",
      "secret_projection": {
        "toml_writes": [
          { "path": "~/.zeroclaw/config.toml", "key": "default_provider", "value": "anthropic" },
          {
            "path": "~/.zeroclaw/config.toml",
            "key": "api_key",
            "value": { "from_secret": "anthropic-key" }
          }
        ],
        "launch": "zeroclaw"
      }
    },
    {
      "id": "generic-mcp",
      "name": "Generic MCP server",
      "tagline": "Custom MCP-compatible agent — bring your own binary",
      "homepage": "https://modelcontextprotocol.io/",
      "install": { "npm": null, "brew": null },
      "config_paths": [],
      "config_snippet": null,
      "required_secrets": [],
      "optional_secrets": [],
      "llm_compat": [],
      "mcp_compatible": true,
      "supported_versions": "*",
      "min_foreman_version": "0.1.2"
    }
  ]
}
