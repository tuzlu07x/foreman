{
  "version": 1,
  "services": [
    {
      "id": "telegram",
      "name": "Telegram",
      "description": "Bot integration for Telegram channel/DM",
      "secret_name": "telegram-bot-token",
      "where_to_get": "https://t.me/BotFather",
      "format_hint": "123456789:ABC-DEF1234567890abcdef",
      "setup_steps": [
        "Open Telegram on your phone or desktop",
        "Search for @BotFather",
        "Send /newbot",
        "Choose a display name (e.g. \"My Foreman Bot\")",
        "Choose a username ending in 'bot' (e.g. fatih_assistant_bot)",
        "Copy the token BotFather sends"
      ],
      "used_by_agents": ["hermes", "openclaw"],
      "open_url_hotkey": true,
      "extra_secrets": [
        {
          "name": "telegram-chat-id",
          "description": "Where the bot should send messages (your DM or a group chat).",
          "format_hint": "-1001234567890 (group) or 123456789 (DM)",
          "where_to_get": null,
          "setup_steps": [
            "Open Telegram and send any message to your bot",
            "In a browser open: https://api.telegram.org/bot<TOKEN>/getUpdates",
            "Find the `chat.id` field in the JSON response",
            "Paste the id here (negative numbers are groups, positive are DMs)"
          ],
          "optional": true
        }
      ]
    },
    {
      "id": "discord",
      "name": "Discord",
      "description": "Bot integration for Discord server",
      "secret_name": "discord-bot-token",
      "where_to_get": "https://discord.com/developers/applications",
      "format_hint": "long opaque string",
      "setup_steps": [
        "Open Discord Developer Portal",
        "Click \"New Application\" and name it",
        "Bot tab → Add Bot",
        "Reset Token → Copy"
      ],
      "used_by_agents": ["hermes", "openclaw"],
      "open_url_hotkey": true
    },
    {
      "id": "slack",
      "name": "Slack",
      "description": "Bot integration with OAuth scopes",
      "secret_name": "slack-bot-token",
      "where_to_get": "https://api.slack.com/apps",
      "format_hint": "starts with xoxb-",
      "setup_steps": [
        "Visit api.slack.com/apps → 'Create New App'",
        "Choose 'From scratch', name the app, pick your workspace",
        "OAuth & Permissions → Bot Token Scopes — add at minimum:",
        "  [x] chat:write     → post messages as the bot",
        "  [x] channels:read  → list public channels the bot can reach",
        "Optional bot scopes — only add if your agent actually needs them:",
        "  [ ] im:history     → read DM history with the bot",
        "  [ ] files:write    → upload files / images",
        "  [ ] groups:read    → list private channels the bot is in",
        "Install to Workspace (top of the OAuth page) → Authorize",
        "Copy the 'Bot User OAuth Token' (starts with xoxb-)"
      ],
      "used_by_agents": ["openclaw"],
      "open_url_hotkey": true
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Personal Access Token for repo access",
      "secret_name": "github-pat",
      "where_to_get": "https://github.com/settings/tokens/new",
      "format_hint": "starts with ghp_",
      "setup_steps": [
        "Visit github.com/settings/tokens/new",
        "Name: 'Foreman agent token' (or anything memorable)",
        "Expiration: 90 days recommended",
        "Required scopes — tick these two:",
        "  [x] repo       → read + write to your repos (public + private)",
        "  [x] read:user  → read your profile (display name, email)",
        "Optional scopes — only tick if your agent actually needs them:",
        "  [ ] read:org   → list your org memberships",
        "  [ ] workflow   → trigger GitHub Actions",
        "  [ ] gist       → read + write your gists",
        "Click 'Generate token' at the bottom",
        "Copy immediately (won't show again — starts with ghp_)"
      ],
      "used_by_agents": ["claude-code", "codex"],
      "open_url_hotkey": true
    },
    {
      "id": "atlassian",
      "name": "Atlassian (Jira / Confluence)",
      "description": "API token for Atlassian cloud",
      "secret_name": "atlassian-api-token",
      "where_to_get": "https://id.atlassian.com/manage-profile/security/api-tokens",
      "format_hint": "long opaque string",
      "setup_steps": [
        "Visit id.atlassian.com/manage-profile/security/api-tokens",
        "Create API token → name it",
        "Copy the token"
      ],
      "used_by_agents": [],
      "open_url_hotkey": true
    },
    {
      "id": "notion",
      "name": "Notion",
      "description": "Integration token for Notion workspace",
      "secret_name": "notion-integration-token",
      "where_to_get": "https://www.notion.so/my-integrations",
      "format_hint": "starts with secret_",
      "setup_steps": [
        "Visit notion.so/my-integrations",
        "New integration → name it",
        "Choose workspace + capabilities",
        "Copy the Internal Integration Token",
        "Share each Notion page you want the integration to access"
      ],
      "used_by_agents": [],
      "open_url_hotkey": true
    }
  ]
}
