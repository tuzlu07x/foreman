{
  "name": "foreman-agent",
  "version": "0.1.2",
  "description": "Your local AI agents talk to each other. You should know what they're saying.",
  "type": "module",
  "bin": {
    "foreman": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "FOREMAN.md",
    "FOREMAN-TUI.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npm test",
    "build:binaries": "node scripts/build-binaries.mjs",
    "dev": "tsup --watch --onSuccess \"node dist/cli/index.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:check": "drizzle-kit check:sqlite"
  },
  "pkg": {
    "scripts": [],
    "assets": [
      "dist/db/migrations/**/*",
      "dist/assets/mascot/**/*",
      "dist/registry/**/*"
    ],
    "targets": [
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-linux-arm64"
    ],
    "outputPath": "dist-binaries"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "local-first",
    "terminal",
    "security",
    "audit",
    "typescript",
    "ink",
    "sqlite"
  ],
  "author": "Fatih Tuzlu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuzlu07x/foreman.git"
  },
  "homepage": "https://github.com/tuzlu07x/foreman#readme",
  "bugs": {
    "url": "https://github.com/tuzlu07x/foreman/issues"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "drizzle-orm": "^0.30.0",
    "ink": "^5.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "react": "^18.0.0",
    "shell-quote": "^1.8.3",
    "smol-toml": "^1.6.1",
    "ulid": "^2.3.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/shell-quote": "^1.7.5",
    "@yao-pkg/pkg": "^6.19.0",
    "drizzle-kit": "^0.20.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
